# Reload configuration
unbind r
bind r source-file ~/.tmux.conf

# Start windows and panes index at 1, not 0.
set -g base-index 1
setw -g pane-base-index 1

# Ensure window index numbers get reordered on delete.
set-option -g renumber-windows on

# don't rename windows automatically
set-option -g allow-rename off

# Use Vi mode
set -g mode-keys vi
set -g status-keys vi

set-option -g focus-events on

# vim pane switching directions
bind-key h select-pane -L
bind-key j select-pane -D
bind-key k select-pane -U
bind-key l select-pane -R

bind '"' split-window -v -c "#{pane_current_path}"
bind '%' split-window -h -c "#{pane_current_path}"

# move status bar to top
set-option -g status-position top

# theming
set -g @catppuccin_window_status_style "rounded"
run ~/.config/tmux/plugins/catppuccin/tmux/catppuccin.tmux

# Make the status line pretty and add some modules
set -g status-right-length 100
set -g status-left-length 100
set -g status-left ""
set -g status-right "#{E:@catppuccin_status_application}"

set -g @catppuccin_window_text " #W"

set -g @catppuccin_window_default_text " #W"
set -g @catppuccin_window_text " #W"
set -g @catppuccin_window_current_text " #W"

# Show pane title (#T) when explicitly set (like Claude Code), otherwise show window name (#W)
# If pane title equals hostname, show window name; if window is "zsh", show directory basename
#set -g u/catppuccin_window_default\_text "#{?#{==:#T,#h},#{?#{==:#W,zsh},#{b:pane\_current\_path},#W},#T}"
#set -g u/catppuccin_window_text "#{?#{==:#T,#h},#{?#{==:#W,zsh},#{b:pane\_current\_path},#W},#T}"
#set -g u/catppuccin_window_current\_text "#{?#{==:#T,#h},#{?#{==:#W,zsh},#{b:pane\_current\_path},#W},#T}"
