#!/bin/sh
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

set -e

parentDirectory="$(cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

displayUsageAndExit() {
	echo "dot -- dotfiles management"
	echo ""
	echo "Usage: dot [options]"
	echo ""
	echo "Options:"
	echo "  -e, --edit             Open dotfiles directory for editing"
	echo "  -s, --skip-defaults    Skip macOS defaults and hostname (faster routine update)"
	echo "  -h, --help             Show this help message and exit"
	exit
}

SKIP_DEFAULTS=false

while test $# -gt 0; do
	case "$1" in
		"-h"|"--help")
			displayUsageAndExit
			;;
		"-e"|"--edit")
			exec "$EDITOR" "$dotfilesDirectory"
			exit
			;;
		"-s"|"--skip-defaults")
			SKIP_DEFAULTS=true
			;;
		*)
			echo "Invalid option: $1"
			displayUsageAndExit
			;;
	esac
	shift
done

export ZSH=$HOME/.dotfiles

# Update dotfiles themselves
echo "› git pull"
git -C $ZSH pull

# macOS defaults and hostname change rarely and are slow (dozens of process
# spawns); skip them on routine updates with --skip-defaults.
if [ "$SKIP_DEFAULTS" = false ]; then
	echo "› macOS defaults"
	$ZSH/macos/set-defaults.sh

	echo "› macOS hostname"
	$ZSH/macos/set-hostname.sh
else
	echo "› skipping macOS defaults and hostname (--skip-defaults)"
fi

# Install homebrew
$ZSH/homebrew/install.sh 2>&1

# Upgrade homebrew
echo "› brew update"
brew update

echo "› brew upgrade"
brew upgrade

# Install software
echo "› script/install"
$ZSH/script/install
