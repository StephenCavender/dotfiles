#!/usr/bin/env bash
set -e

name="$1"

if [[ -z "$name" ]]; then
  echo "Usage: worktree-rm <worktree>" >&2
  exit 1
fi

# Resolve project root — works from main/ or any sibling worktree.
#   git_common_dir → /path/to/project/main/.git
#   main_dir       → /path/to/project/main
#   project_root   → /path/to/project
git_common_dir="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
main_dir="$(dirname "$git_common_dir")"
project_root="$(dirname "$main_dir")"

# Extract the full branch name from the porcelain worktree list
# before the worktree is removed.  Porcelain groups entries like:
#   worktree /path/to/project/<name>
#   HEAD abc1234
#   branch refs/heads/feature/my-branch
branch=$(git worktree list --porcelain | awk -v name="$name" '
  /^worktree / { wt = $2 }
  /^branch /  { if (wt ~ ("/" name "$")) print substr($2, length("refs/heads/") + 1) }
')

if [[ -z "$branch" ]]; then
  echo "No worktree found matching '$name'" >&2
  exit 1
fi

git worktree remove "$project_root/$name"
git branch -D "$branch"
