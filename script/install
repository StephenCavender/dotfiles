#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

WORK_BREWFILE=false

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --work|-w)
            WORK_BREWFILE=true
            shift
            ;;
        *)
            echo "Unknown argument: $1"
            echo "Usage: $0 [--work|-w]"
            exit 1
            ;;
    esac
done

cd "$(dirname "$0")"/..

# Export DOTFILES_ROOT so nested install.sh files can rely on it
export DOTFILES_ROOT
DOTFILES_ROOT="$(pwd -P)"

# ZSH is used by some installers (e.g. newsboat) as the dotfiles root alias
export ZSH="${ZSH:-$DOTFILES_ROOT}"

echo "› brew bundle"
brew bundle

if [ "$WORK_BREWFILE" = true ] && [ -f "Brewfile.work" ]; then
    echo "› brew bundle --file=Brewfile.work"
    brew bundle --file=Brewfile.work
elif [ "$WORK_BREWFILE" = true ] && [ ! -f "Brewfile.work" ]; then
    echo "› Brewfile.work not found, skipping work brewfile"
elif [ "$WORK_BREWFILE" = false ] && [ -f "Brewfile.work" ]; then
    echo "› Brewfile.work found. Use --work flag to install work packages."
fi

# Run homebrew/install.sh first — other installers may depend on tools it provides
if [ -f "homebrew/install.sh" ]; then
    echo "› homebrew/install.sh"
    bash "homebrew/install.sh"
fi

# Run all remaining installers, collecting failures
failed=()

while IFS= read -r -d '' installer; do
    echo "› ${installer}"
    if ! bash "${installer}"; then
        echo "  failed: ${installer}" >&2
        failed+=("${installer}")
    fi
done < <(find . -mindepth 2 -name install.sh ! -path './homebrew/*' -print0)

# Summary
if [ ${#failed[@]} -eq 0 ]; then
    echo "› all installers completed successfully"
else
    echo "› ${#failed[@]} installer(s) failed:" >&2
    printf '  %s\n' "${failed[@]}" >&2
    exit 1
fi
